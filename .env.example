# =============================================================================
# SOC Agent - Configuracion de Entorno
# =============================================================================
# Copia este archivo como .env y completa con tus valores:
#   cp .env.example .env
#
# Las APIs marcadas con [GRATUITA] tienen tier gratuito disponible.
# Las marcadas con [SIN KEY] no requieren API key.
# =============================================================================


# =============================================================================
# FLASK
# =============================================================================
FLASK_APP=wsgi.py
FLASK_ENV=development
# FLASK_ENV=production
SECRET_KEY=cambia-esto-por-una-clave-secreta-larga-y-aleatoria
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"


# =============================================================================
# BASE DE DATOS (PostgreSQL)
# =============================================================================
DATABASE_URL=postgresql://soc_admin:tu_password@localhost:5432/soc_agent
# Para SQLite (desarrollo rapido, sin PostgreSQL):
# DATABASE_URL=sqlite:///soc_agent.db


# =============================================================================
# REDIS (Opcional - para cache y rate limiting)
# =============================================================================
# REDIS_URL=redis://localhost:6379/0


# =============================================================================
# THREAT INTELLIGENCE APIs
# =============================================================================

# --- Reputacion ---

# VirusTotal [GRATUITA - 500 req/dia]
# https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=

# AbuseIPDB [GRATUITA - 1000 req/dia]
# https://www.abuseipdb.com/register
ABUSEIPDB_API_KEY=

# GreyNoise [GRATUITA - Community]
# https://viz.greynoise.io/signup
GREYNOISE_API_KEY=

# Pulsedive [GRATUITA - limitada]
# https://pulsedive.com/register
PULSEDIVE_API_KEY=

# --- Infraestructura ---

# Shodan [GRATUITA - limitada]
# https://account.shodan.io/register
SHODAN_API_KEY=

# Shodan InternetDB [SIN KEY]
# No requiere configuracion

# Criminal IP [$]
# https://www.criminalip.io/
CRIMINAL_IP_API_KEY=

# SecurityTrails [GRATUITA - 50 req/mes]
# https://securitytrails.com/app/signup
SECURITYTRAILS_API_KEY=

# --- Malware ---

# ThreatFox [SIN KEY]
# https://threatfox.abuse.ch/

# MalwareBazaar [SIN KEY]
# https://bazaar.abuse.ch/

# Hybrid Analysis [GRATUITA]
# https://www.hybrid-analysis.com/apikeys/info
HYBRID_ANALYSIS_API_KEY=

# --- URLs ---

# URLhaus [SIN KEY]
# https://urlhaus.abuse.ch/

# URLScan [GRATUITA - limitada]
# https://urlscan.io/user/signup
URLSCAN_API_KEY=

# Google Safe Browsing [GRATUITA]
# https://console.cloud.google.com/apis/library/safebrowsing.googleapis.com
GOOGLE_SAFEBROWSING_API_KEY=

# --- Inteligencia ---

# AlienVault OTX [GRATUITA - ilimitada]
# https://otx.alienvault.com/api
OTX_API_KEY=

# IP-API [SIN KEY - Geolocalizacion]
# https://ip-api.com/


# =============================================================================
# LLM PROVIDERS (al menos 1 requerido para analisis con IA)
# =============================================================================

# Proveedor por defecto: xai, openai, groq, gemini
DEFAULT_LLM_PROVIDER=groq

# xAI (Grok)
# https://console.x.ai/
XAI_API_KEY=
XAI_MODEL=grok-beta

# OpenAI (GPT-4)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Groq [GRATUITA]
# https://console.groq.com/
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash


# =============================================================================
# SEGURIDAD
# =============================================================================
# Rate limiting
# RATELIMIT_DEFAULT=100/hour
# RATELIMIT_STORAGE_URL=redis://localhost:6379/1

# Session
# SESSION_COOKIE_SECURE=true   # Activar solo con HTTPS
# PREFERRED_URL_SCHEME=https


# =============================================================================
# MONITOREO (Opcional)
# =============================================================================
# Sentry - Error tracking
# https://sentry.io/
# SENTRY_DSN=

# Logging level: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO
